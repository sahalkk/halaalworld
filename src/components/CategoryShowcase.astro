---
import InteractivePattern from './InteractivePattern.astro';

const categories = [
  {
    id: "prayer-mats",
    title: "Prayer Mats",
    tagline: "Sacred spaces redefined",
    image: "/images/prayer_mat.png",
    aspect: "md:aspect-[3/4] aspect-[4/5]",
    gridSpan: "md:col-span-6 lg:col-span-5"
  },
  {
    id: "oud-fragrance",
    title: "Oud & Fragrance",
    tagline: "Distilled essence of tradition",
    image: "/images/oud_fragrance.png",
    aspect: "md:aspect-square aspect-[4/5]",
    gridSpan: "md:col-span-6 lg:col-span-7"
  },
  {
    id: "modest-wear",
    title: "Modest Wear",
    tagline: "Elegance woven in modesty",
    image: "/images/modest_wear.png",
    aspect: "md:aspect-square aspect-[4/5]",
    gridSpan: "md:col-span-6 lg:col-span-7"
  },
  {
    id: "home-decor",
    title: "Islamic Home Decor",
    tagline: "Harmonious sacred geometries",
    image: "/images/home_decor.png",
    aspect: "md:aspect-[3/4] aspect-[4/5]",
    gridSpan: "md:col-span-6 lg:col-span-5"
  }
];
---

<section class="py-24 md:py-36 bg-luxury-black relative" id="collections">
  <!-- Subtle ambient decorative grids -->
  <div class="absolute inset-0 bg-[radial-gradient(#c6a85a06_1px,transparent_1px)] [background-size:32px_32px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header Block -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16 md:mb-24">
      <div class="flex flex-col gap-4">
        <span class="font-sans text-xs uppercase tracking-[0.3em] text-gold-400 font-semibold scroll-reveal-cat">
          The Collections
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-white tracking-wide font-normal leading-tight scroll-reveal-cat">
          Curated Portals of <span class="italic font-light">Beauty</span>
        </h2>
      </div>
      <p class="font-sans text-xs uppercase tracking-widest text-gray-400 max-w-sm font-light leading-relaxed border-l border-gold-500/20 pl-6 scroll-reveal-cat">
        Explore our architectural, sensory, and woven catalogs, each designed to nurture mindful remembrance in the modern home.
      </p>
    </div>

    <!-- Asymmetrical Masonry Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12">
      {categories.map((cat, index) => (
        <a 
          href={`#${cat.id}`} 
          class={`relative group flex flex-col justify-end overflow-hidden ${cat.gridSpan} category-card-scroll`}
          id={`cat-card-${index}`}
        >
          <!-- Outer border decoration -->
          <div class="absolute -inset-2 border border-gold-500/0 group-hover:border-gold-500/10 transition-all duration-700 pointer-events-none z-0"></div>

          <!-- Image Container with aspect ratio -->
          <div class={`relative w-full ${cat.aspect} overflow-hidden bg-luxury-charcoal z-10 border border-gold-500/5`}>
            <!-- Image asset -->
            <img 
              src={cat.image} 
              alt={cat.title} 
              class="w-full h-full object-cover scale-100 group-hover:scale-[1.03] transition-transform duration-[1.5s] ease-out filter brightness-95 saturate-[0.85] contrast-[0.95] cat-card-image"
            />
            
            <!-- Dark Overlay Vignette -->
            <div class="absolute inset-0 card-overlay transition-all duration-500"></div>

            <!-- Interactive Warp/Glow pattern overlay -->
            <InteractivePattern opacity="opacity-0 group-hover:opacity-30 transition-opacity duration-500" class="z-20" />
            
            <!-- Fine gold inner frame -->
            <div class="absolute inset-4 border border-white/5 group-hover:border-gold-500/20 transition-colors duration-500 pointer-events-none z-20"></div>

            <!-- Content Card floating on image bottom -->
            <div class="absolute bottom-8 left-8 right-8 z-30 flex justify-between items-end">
              <div class="flex flex-col gap-2">
                <span class="font-sans text-[10px] uppercase tracking-widest text-gold-400 font-semibold transform translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                  {cat.tagline}
                </span>
                <h3 class="font-serif text-2xl text-white tracking-wide font-normal group-hover:text-gold-300 transition-colors duration-300">
                  {cat.title}
                </h3>
              </div>

              <!-- Animated Luxury arrow indicator -->
              <div class="w-10 h-10 border border-white/10 flex items-center justify-center group-hover:border-gold-500/30 group-hover:bg-gold-500 transition-all duration-500 rounded-none shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-white group-hover:text-luxury-black transition-colors duration-500 transform group-hover:translate-x-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
