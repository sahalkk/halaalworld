---
const products = [
  {
    name: "The Medina Star Prayer Mat",
    collection: "Silk & Gold Collection",
    price: "$280",
    details: "Woven with double-spun silk and metallic gold threads",
    image: "/images/prayer_mat.png"
  },
  {
    name: "Pure Dehn Al Oud",
    collection: "Imperial Fragrances",
    price: "$340",
    details: "Aged 15 years, distilled from premium wild Cambodi agarwood",
    image: "/images/oud_fragrance.png"
  },
  {
    name: "The Al-Andalus Incense Burner",
    collection: "Sacred Geometries Home",
    price: "$195",
    details: "Hand-chiseled brushed brass with geometric lattice vents",
    image: "/images/home_decor.png"
  }
];
---

<section class="py-24 md:py-36 bg-luxury-black relative" id="featured-products">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- Header Block -->
    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-24 flex flex-col gap-4">
      <span class="font-sans text-xs uppercase tracking-[0.3em] text-gold-400 font-semibold scroll-reveal-prod">
        Signature Objects
      </span>
      <h2 class="font-serif text-4xl md:text-5xl text-white tracking-wide font-normal scroll-reveal-prod">
        The Featured <span class="italic font-light">Gallery</span>
      </h2>
      <p class="font-sans text-sm text-gray-400 font-light leading-relaxed tracking-wide mt-2 scroll-reveal-prod">
        Each item is produced in limited quantities, individually numbered, and packaged in custom cedar-wood boxes.
      </p>
    </div>

    <!-- 3-Column Luxury Product Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      {products.map((prod, index) => (
        <div class="flex flex-col gap-6 group product-card-scroll" id={`prod-card-${index}`}>
          <!-- Image Box with thin border -->
          <div class="relative overflow-hidden aspect-[3/4] bg-luxury-charcoal border border-gold-500/10 shadow-lg">
            <img 
              src={prod.image} 
              alt={prod.name} 
              class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-[1.5s] ease-out filter brightness-95 saturate-[0.8] contrast-[0.95]"
            />
            
            <!-- Dark Overlay Vignette -->
            <div class="absolute inset-0 product-overlay"></div>
            
            <!-- Custom Fine gold inner frame -->
            <div class="absolute inset-3 border border-white/5 group-hover:border-gold-500/20 transition-colors duration-500 pointer-events-none"></div>

            <!-- Floating Quick Inquiry Overlay -->
            <div class="absolute inset-0 flex items-center justify-center bg-luxury-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 backdrop-blur-[2px]">
              <button class="font-sans text-[10px] uppercase tracking-[0.25em] font-semibold text-luxury-black bg-white group-hover:bg-gold-500 px-6 py-4 transition-all duration-300 shadow-xl rounded-none transform translate-y-3 group-hover:translate-y-0 duration-500 hover:bg-gold-400">
                Request Private Viewing
              </button>
            </div>
          </div>

          <!-- Product Details -->
          <div class="flex flex-col gap-2 relative pl-2 border-l border-gold-500/10">
            <div class="flex justify-between items-baseline gap-4">
              <span class="font-sans text-[10px] uppercase tracking-widest text-gold-400 font-medium">
                {prod.collection}
              </span>
              <span class="font-serif text-sm text-gold-300 font-semibold">
                {prod.price}
              </span>
            </div>
            
            <h3 class="font-serif text-xl text-white tracking-wide font-normal group-hover:text-gold-300 transition-colors duration-300">
              {prod.name}
            </h3>

            <p class="font-sans text-xs text-gray-500 font-light leading-relaxed tracking-wide">
              {prod.details}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
