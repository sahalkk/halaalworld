---
interface Props {
	class?: string;
	opacity?: string;
}

const { class: className = "", opacity = "opacity-20" } = Astro.props;
---

<div class={`absolute inset-0 pointer-events-none overflow-hidden select-none interactive-pattern-container ${className}`} style={`opacity: ${opacity}`}>
  <!-- The Static Base Pattern -->
  <svg class="absolute inset-0 w-full h-full" style="color: var(--pattern-stroke, rgba(198, 168, 90, 0.1));" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="islamic-star-base" width="80" height="80" patternUnits="userSpaceOnUse">
        <!-- Rub el Hizb / 8-pointed star -->
        <rect x="25" y="25" width="30" height="30" fill="none" stroke="currentColor" stroke-width="0.8" transform="rotate(0, 40, 40)"></rect>
        <rect x="25" y="25" width="30" height="30" fill="none" stroke="currentColor" stroke-width="0.8" transform="rotate(45, 40, 40)"></rect>
        <circle cx="40" cy="40" r="5" fill="none" stroke="currentColor" stroke-width="0.8"></circle>
        
        <!-- Connecting network lines -->
        <line x1="40" y1="0" x2="40" y2="25" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 3"></line>
        <line x1="40" y1="55" x2="40" y2="80" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 3"></line>
        <line x1="0" y1="40" x2="25" y2="40" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 3"></line>
        <line x1="55" y1="40" x2="80" y2="40" stroke="currentColor" stroke-width="0.4" stroke-dasharray="1 3"></line>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#islamic-star-base)"></rect>
  </svg>

  <!-- The Interactive Glowing & Warped Overlay Pattern -->
  <svg class="absolute inset-0 w-full h-full interactive-glow-pattern filter-warp" style="color: var(--pattern-glow, rgba(198, 168, 90, 0.4));" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <!-- Warp Filter -->
      <filter id="warp-filter" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="2" result="noise" seed="1"></feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" id="displacement-map"></feDisplacementMap>
      </filter>
      
      <pattern id="islamic-star-glow" width="80" height="80" patternUnits="userSpaceOnUse">
        <rect x="25" y="25" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.2" transform="rotate(0, 40, 40)"></rect>
        <rect x="25" y="25" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.2" transform="rotate(45, 40, 40)"></rect>
        <circle cx="40" cy="40" r="5" fill="none" stroke="currentColor" stroke-width="1.2"></circle>
        
        <!-- Connected grid -->
        <line x1="40" y1="0" x2="40" y2="25" stroke="currentColor" stroke-width="0.6"></line>
        <line x1="40" y1="55" x2="40" y2="80" stroke="currentColor" stroke-width="0.6"></line>
        <line x1="0" y1="40" x2="25" y2="40" stroke="currentColor" stroke-width="0.6"></line>
        <line x1="55" y1="40" x2="80" y2="40" stroke="currentColor" stroke-width="0.6"></line>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#islamic-star-glow)" filter="url(#warp-filter)" class="pattern-rect"></rect>
  </svg>
</div>

<style>
  .interactive-pattern-container {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .interactive-glow-pattern {
    /* Mask out everything except a radial spotlight around the custom CSS variables */
    mask-image: radial-gradient(
      circle 160px at var(--mouse-x, -9999px) var(--mouse-y, -9999px),
      black 0%,
      rgba(0, 0, 0, 0.5) 40%,
      transparent 100%
    );
    -webkit-mask-image: radial-gradient(
      circle 160px at var(--mouse-x, -9999px) var(--mouse-y, -9999px),
      black 0%,
      rgba(0, 0, 0, 0.5) 40%,
      transparent 100%
    );
    transition: opacity 0.3s ease;
  }
</style>

<script>
  import { gsap } from 'gsap';

  // Find all interactive patterns on the page
  const containers = document.querySelectorAll('.interactive-pattern-container');

  containers.forEach(container => {
    // Find parent element to track hover over the entire parent section/card
    const parent = container.parentElement;
    if (!parent) return;

    const displacementMap = container.querySelector('#displacement-map');
    const glowPattern = container.querySelector('.interactive-glow-pattern') as HTMLElement;

    // Track mouse movement over the parent container
    parent.addEventListener('mousemove', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      const rect = parent.getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left;
      const y = mouseEvent.clientY - rect.top;

      // Set CSS variables for radial gradient mask
      glowPattern.style.setProperty('--mouse-x', `${x}px`);
      glowPattern.style.setProperty('--mouse-y', `${y}px`);

      // Dynamically animate displacement scale on mouse move to warp the SVG grid
      if (displacementMap) {
        gsap.to(displacementMap, {
          attr: { scale: 15 },
          duration: 0.3,
          ease: 'power2.out'
        });
      }
    });

    // Reset warp on mouse leave
    parent.addEventListener('mouseleave', () => {
      if (displacementMap) {
        gsap.to(displacementMap, {
          attr: { scale: 0 },
          duration: 0.8,
          ease: 'power2.out'
        });
      }
      // Move glow out of screen
      glowPattern.style.setProperty('--mouse-x', `-9999px`);
      glowPattern.style.setProperty('--mouse-y', `-9999px`);
    });
  });
</script>
