---
import InteractivePattern from './InteractivePattern.astro';
---

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-luxury-black" id="hero-section">
  <!-- Background Image with Zoom & Dark Gradient Vignette -->
  <div class="absolute inset-0 z-0 select-none overflow-hidden">
    <img 
      src="/images/hero.png" 
      alt="Luxury Islamic Lifestyle interior" 
      class="w-full h-full object-cover scale-105 opacity-60 filter brightness-90 saturate-[0.85]" 
      id="hero-bg-img"
    />
    <!-- Deep Green-Black Vignette Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-luxury-black via-luxury-black/60 to-transparent"></div>
    <div class="absolute inset-0 bg-radial-gradient(circle at center, transparent 30%, rgba(5, 8, 6, 0.8) 100%)"></div>
  </div>

  <!-- Interactive Star Pattern Overlay (Subtle) -->
  <InteractivePattern opacity="opacity-15" class="z-10" />

  <!-- Hero Content -->
  <div class="relative z-20 max-w-5xl mx-auto px-6 md:px-12 text-center flex flex-col items-center justify-center h-full pt-16">
    <span class="font-sans text-xs uppercase tracking-[0.4em] text-gold-400 mb-6 block md:mb-8 font-semibold animate-fade-up opacity-0" id="hero-kicker">
      Introducing HalaalWorld
    </span>
    
    <h1 class="font-serif text-5xl md:text-8xl text-white tracking-wide leading-[1.1] mb-8 font-normal max-w-4xl" id="hero-heading">
      <span class="inline-block overflow-hidden py-2"><span class="inline-block translate-y-[100%]">Live</span></span>
      <span class="inline-block overflow-hidden py-2"><span class="inline-block translate-y-[100%] text-gold-300 italic">Your</span></span>
      <span class="inline-block overflow-hidden py-2"><span class="inline-block translate-y-[100%]">Faith.</span></span>
      <br class="hidden md:inline" />
      <span class="inline-block overflow-hidden py-2"><span class="inline-block translate-y-[100%] text-gold-500 font-medium">Beautifully.</span></span>
    </h1>

    <p class="font-sans text-sm md:text-lg text-gray-300 font-light leading-relaxed max-w-2xl mb-12 tracking-wide md:mb-16 opacity-0" id="hero-subtext">
      Cultivating high-end lifestyle essentials that harmonize elegant modern design with the purity and grace of halal traditions.
    </p>

    <div class="flex flex-col sm:flex-row gap-6 opacity-0" id="hero-ctas">
      <a 
        href="#collections" 
        class="font-sans text-xs uppercase tracking-[0.25em] font-semibold text-luxury-black bg-gold-500 hover:bg-gold-400 px-10 py-5 transition-all duration-500 hover:shadow-[0_0_30px_rgba(198,168,90,0.3)] hover:-translate-y-0.5"
      >
        Explore Collections
      </a>
      <a 
        href="#philosophy" 
        class="font-sans text-xs uppercase tracking-[0.25em] font-semibold text-white border border-white/20 hover:border-gold-500 hover:text-gold-400 px-10 py-5 transition-all duration-500 backdrop-blur-sm bg-white/5 hover:bg-white/10"
      >
        Our Philosophy
      </a>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-3 opacity-0" id="hero-scroll-indicator">
    <span class="font-sans text-[10px] uppercase tracking-[0.3em] text-gray-500 font-medium">Scroll to Discover</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-gold-500/80 to-transparent relative overflow-hidden">
      <div class="w-full h-4 bg-gold-400 absolute top-0" id="scroll-indicator-dot"></div>
    </div>
  </div>
</section>

<style>
  /* Extra support for custom Radial Gradient */
  .bg-radial-gradient\(circle\ at\ center\,\ transparent\ 30\%\,\ rgba\(5\,\ 8\,\ 6\,\ 0\.8\)\ 100\%\) {
    background: radial-gradient(circle at center, transparent 30%, rgba(5, 8, 6, 0.8) 100%);
  }
</style>
